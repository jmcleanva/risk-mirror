        "partitions": [
          {
            "name": "BLS OEWS Data",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source =",
                "        Excel.Workbook(",
                "            File.Contents(",
                "                \"C:\\Users\\jspmc\\OneDrive\\Risk Mirror\\Go Forward V2 Sources\\national_M2025_dl.xlsx\"",
                "            ),",
                "            null,",
                "            true",
                "        ),",
                "",
                "    national_M2025_dl_Sheet =",
                "        Source{[Item = \"national_M2025_dl\", Kind = \"Sheet\"]}[Data],",
                "",
                "    #\"Promoted Headers\" =",
                "        Table.PromoteHeaders(",
                "            national_M2025_dl_Sheet,",
                "            [PromoteAllScalars = true]",
                "        ),",
                "",
                "    ColumnsToClean = {",
                "        \"H_MEAN\", \"A_MEAN\",",
                "        \"H_PCT10\", \"H_PCT25\", \"H_MEDIAN\", \"H_PCT75\", \"H_PCT90\",",
                "        \"A_PCT10\", \"A_PCT25\", \"A_MEDIAN\", \"A_PCT75\", \"A_PCT90\"",
                "    },",
                "",
                "    #\"Cleaned Suppression Symbols\" =",
                "        Table.TransformColumns(",
                "            #\"Promoted Headers\",",
                "            List.Transform(",
                "                ColumnsToClean,",
                "                each {",
                "                    _,",
                "                    each if _ = \"*\" or _ = \"#\" then null else _,",
                "                    type any",
                "                }",
                "            )",
                "        ),",
                "",
                "    #\"Changed Type\" =",
                "        Table.TransformColumnTypes(",
                "            #\"Cleaned Suppression Symbols\",",
                "            {",
                "                {\"AREA\", Int64.Type},",
                "                {\"AREA_TITLE\", type text},",
                "                {\"AREA_TYPE\", Int64.Type},",
                "                {\"PRIM_STATE\", type text},",
                "                {\"NAICS\", Int64.Type},",
                "                {\"NAICS_TITLE\", type text},",
                "                {\"I_GROUP\", type text},",
                "                {\"OWN_CODE\", Int64.Type},",
                "                {\"OCC_CODE\", type text},",
                "                {\"OCC_TITLE\", type text},",
                "                {\"O_GROUP\", type text},",
                "                {\"TOT_EMP\", Int64.Type},",
                "                {\"EMP_PRSE\", type number},",
                "                {\"JOBS_1000\", type any},",
                "                {\"LOC_QUOTIENT\", type any},",
                "                {\"PCT_TOTAL\", type any},",
                "                {\"PCT_RPT\", type any},",
                "                {\"H_MEAN\", type number},",
                "                {\"A_MEAN\", Int64.Type},",
                "                {\"MEAN_PRSE\", type number},",
                "                {\"H_PCT10\", type number},",
                "                {\"H_PCT25\", type number},",
                "                {\"H_MEDIAN\", type number},",
                "                {\"H_PCT75\", type number},",
                "                {\"H_PCT90\", type number},",
                "                {\"A_PCT10\", Int64.Type},",
                "                {\"A_PCT25\", Int64.Type},",
                "                {\"A_MEDIAN\", Int64.Type},",
                "                {\"A_PCT75\", Int64.Type},",
                "                {\"A_PCT90\", Int64.Type},",
                "                {\"ANNUAL\", type logical},",
                "                {\"HOURLY\", type text}",
                "            }",
                "        ),",
                "",
                "    #\"Filtered Rows\" =",
                "        Table.SelectRows(",
                "            #\"Changed Type\",",
                "            each [O_GROUP] = \"detailed\"",
                "        ),",
                "",
                "    #\"Renamed Columns\" =",
                "        Table.RenameColumns(",
                "            #\"Filtered Rows\",",
                "            {",
                "                {\"TOT_EMP\", \"Total Employment\"},",
                "                {\"A_MEDIAN\", \"Median Wage\"},",
                "                {\"A_PCT10\", \"10th Percentile Wage\"},",
                "                {\"A_PCT25\", \"25th Percentile Wage\"},",
                "                {\"A_PCT75\", \"75th Percentile Wage\"},",
                "                {\"A_PCT90\", \"90th Percentile Wage\"}",
                "            }",
                "        )",
                "in",
                "    #\"Renamed Columns\""
              ]
            }
          }
        ],
