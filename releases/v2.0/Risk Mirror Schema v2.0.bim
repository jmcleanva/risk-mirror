                "        }",
                "    ),",
                "    #\"Filtered Rows\" = Table.SelectRows(",
                "        #\"Changed Type\",",
                "        each Text.Contains([#\"O*NET-SOC Code\"], \".00\")",
                "    ),",
                "    #\"Replaced Value\" = Table.ReplaceValue(",
