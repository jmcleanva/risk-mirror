      {
        "name": "_Calcs",
        "lineageTag": "0dbb046e-8d0a-47aa-867b-120fd4e45aeb",
        "partitions": [
          {
            "name": "_Calcs",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText(\"i45WKknNLVCKjQUA\", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Test = _t]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"Test\", type text}}),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Changed Type\",{\"Test\"})",
                "in",
                "    #\"Removed Columns\""
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Employment 2024",
            "expression": [
              "",
              "CALCULATE(",
              "    SUM('BLS OEWS Fact'[Total Employment]),",
              "    'BLS OEWS Fact'[OEWS Year] = 2024",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "2fbf3bdb-4bc7-4229-a4be-39e2b3e2ec25"
          },
          {
            "name": "Employment 2025",
            "expression": [
              "",
              "CALCULATE(",
              "    SUM('BLS OEWS Fact'[Total Employment]),",
              "    'BLS OEWS Fact'[OEWS Year] = 2025",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "20ee21d1-f230-41a4-89d0-7e08d8f25a81"
          },
          {
            "name": "Employment Change",
            "expression": [
              "",
              "VAR Emp2024 = [Employment 2024]",
              "VAR Emp2025 = [Employment 2025]",
              "RETURN",
              "IF(",
              "    ISBLANK(Emp2024) || ISBLANK(Emp2025),",
              "    BLANK(),",
              "    Emp2025 - Emp2024",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "9eb68ab5-13a0-48f5-a2a5-ab6753ea42aa"
          },
          {
            "name": "Employment % Change",
            "expression": [
              "",
              "VAR Emp2024 = [Employment 2024]",
              "VAR Emp2025 = [Employment 2025]",
              "RETURN",
              "IF(",
              "    ISBLANK(Emp2024) || ISBLANK(Emp2025),",
              "    BLANK(),",
              "    DIVIDE(Emp2025 - Emp2024, Emp2024)",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "5814845e-c187-43f2-8eb6-381aabca26fd"
          },
          {
            "name": "Median Wage 2024",
            "expression": [
              "",
              "CALCULATE(",
              "    SELECTEDVALUE('BLS OEWS Fact'[Median Wage]),",
              "    'BLS OEWS Fact'[OEWS Year] = 2024",
              ")"
            ],
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "lineageTag": "c99ae44d-9a0d-4a3b-9d9c-27bedfd0fa7b"
          },
          {
            "name": "Median Wage 2025",
            "expression": [
              "",
              "CALCULATE(",
              "    SELECTEDVALUE('BLS OEWS Fact'[Median Wage]),",
              "    'BLS OEWS Fact'[OEWS Year] = 2025",
              ")"
            ],
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "lineageTag": "ee8ec004-510c-4c24-bb53-cbc81c6bf93a"
          },
          {
            "name": "Median Wage Change",
            "expression": [
              "",
              "VAR Wage2024 = [Median Wage 2024]",
              "VAR Wage2025 = [Median Wage 2025]",
              "RETURN",
              "IF(",
              "    ISBLANK(Wage2024) || ISBLANK(Wage2025),",
              "    BLANK(),",
              "    Wage2025 - Wage2024",
              ")"
            ],
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "lineageTag": "33790c0d-0aea-4c8e-b8cc-35aa029ecc36"
          },
          {
            "name": "Median Wage % Change",
            "expression": [
              "",
              "VAR Wage2024 = [Median Wage 2024]",
              "VAR Wage2025 = [Median Wage 2025]",
              "RETURN",
              "IF(",
              "    ISBLANK(Wage2024) || ISBLANK(Wage2025),",
              "    BLANK(),",
              "    DIVIDE(Wage2025 - Wage2024, Wage2024)",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "2cd97b04-b45d-4525-aa23-76a6d46d462c"
          }
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
