              "type": "m",
              "expression": [
                "let",
                "    Source = #\"BLS OEWS Data\",",
                "    #\"Removed Other Columns\" = Table.SelectColumns(Source,{\"OCC_CODE\", \"OCC_TITLE\"}),",
                "    #\"Added Custom\" = Table.AddColumn(#\"Removed Other Columns\", \"Major Group Code\", each Text.Start([OCC_CODE], 2)),",
                "    #\"Added Custom1\" = Table.AddColumn(#\"Added Custom\", \"Minor Group Code\", each if Text.Start([OCC_CODE],5) = \"15-12\" then \"15-12\"",
                "else if Text.Start([OCC_CODE],5) = \"31-11\" then \"31-11\"",
                "else if Text.Start([OCC_CODE],5) = \"51-51\" then \"51-51\"",
                "else Text.Start([OCC_CODE],2) & \"-\" & Text.Middle([OCC_CODE],3,1) & \"0\"),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Added Custom1\",{{\"Major Group Code\", type text}, {\"Minor Group Code\", type text}}),",
                "    #\"Removed Duplicates\" = Table.Distinct(#\"Changed Type\", {\"Minor Group Code\", \"Major Group Code\", \"OCC_CODE\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Removed Duplicates\",{{\"OCC_CODE\", \"SOC Code\"}}),",
                "    #\"Merged Queries\" = Table.NestedJoin(#\"Renamed Columns\", {\"Major Group Code\"}, #\"SOC Major Group Dim\", {\"Major Group Code\"}, \"SOC Major Group Dim\", JoinKind.LeftOuter),",
                "    #\"Expanded SOC Major Group Dim\" = Table.ExpandTableColumn(#\"Merged Queries\", \"SOC Major Group Dim\", {\"Major Group Name\"}, {\"Major Group Name\"}),",
                "    #\"Merged Queries1\" = Table.NestedJoin(#\"Expanded SOC Major Group Dim\", {\"Minor Group Code\"}, #\"SOC Minor Group Dim\", {\"Minor Group Code\"}, \"SOC Minor Group Dim\", JoinKind.LeftOuter),",
                "    #\"Expanded SOC Minor Group Dim\" = Table.ExpandTableColumn(#\"Merged Queries1\", \"SOC Minor Group Dim\", {\"Minor Group Name\"}, {\"Minor Group Name\"})",
                "in",
                "    #\"Expanded SOC Minor Group Dim\""
