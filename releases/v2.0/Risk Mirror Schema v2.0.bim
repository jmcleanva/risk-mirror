        "partitions": [
          {
            "name": "BLS OEWS Fact",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Table.Combine({#\"BLS OEWS 2024 Staging\", #\"BLS OEWS 2025 Staging\"})",
                "in",
                "    Source"
              ]
            }
          }
        ],
        "annotations": [
